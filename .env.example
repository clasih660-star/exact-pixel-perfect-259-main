# ── App URL / public origin ─────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
# Optional aliases referenced by some server helpers / callbacks.
PUBLIC_APP_URL=http://localhost:3000
VITE_APP_URL=http://localhost:3000

# ── Supabase core configuration ─────────────────────────────────────
# Preferred names used by the current codebase.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional backward-compatible alias used by some storage helpers.
SUPABASE_SERVICE_KEY=

# Client-side Vite variables.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Backward-compatible aliases also supported by parts of the app.
SUPABASE_ANON_KEY=
VITE_SUPABASE_ANON_KEY=

# ── AI providers ────────────────────────────────────────────────────
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
# Optional legacy AI gateway key used by autonomous teaching fallback paths.
LOVABLE_API_KEY=

# ── Institution billing / monthly classroom rental ─────────────────
# Required for Paystack checkout, payment verification, and monthly plans.
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# ── Outbound email / institution invites ───────────────────────────
# Current code sends mail through a serverless/supabase email function.
SUPABASE_EMAIL_FUNCTION_URL=
SUPABASE_EMAIL_FUNCTION_BEARER=
# Provider passed through to the email function.
EMAIL_PROVIDER=supabase_function
RESEND_API_KEY=
EMAIL_PROVIDER_API_KEY=
# Legacy/alternate SMTP-style settings retained for external workers if needed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Klassruum <noreply@klassruum.com>"

# ── Local TTS (Kokoro / Piper fallback) ──────────────────────────
LOCAL_TTS_SECRET=dev-secret
LOCAL_KOKORO_TTS_URL=http://localhost:8008
LOCAL_PIPER_TTS_URL=http://localhost:8008

# ── ElevenLabs TTS (premium — used as primary provider) ──────────
# Sign up at https://elevenlabs.io and get your API key from Profile → API Keys.
# When this key is set, all teacher voices will use ElevenLabs for natural,
# human-quality speech. Without it, the system falls back to local TTS.
ELEVENLABS_API_KEY=
# Model: eleven_multilingual_v2 (best quality) or eleven_turbo_v2_5 (faster)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
